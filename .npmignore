# The "files" field in package.json controls what gets published.
# This file is a safety net — everything here is excluded even if accidentally matched.

# Next.js app (not needed by consumers)
app/
components/
public/
content/
styles/

# Config & tooling
.github/
.next/
.vscode/
scripts/
next.config.*
tailwind.config.*
postcss.config.*
tsconfig*.json
eslint.config.*
.eslintrc*
.prettierrc*
.editorconfig

# Lock files & logs
package-lock.json
bun.lock
yarn.lock
*.log
*.tsbuildinfo

# Env
.env
.env.*

# Docs & meta
README.md
CONTRIBUTING.md
EXPORT_GUIDELINES.md
CLAUDE.md
PRIVACY.md
SUPPORT.md
*.md

# Tests
tests/
coverage/
jest.config.*
cypress/

# Misc
node_modules/
.DS_Store
*.pem
